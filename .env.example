# Slack
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Jira
JIRA_SERVER=https://jirap.corp.ebay.com
JIRA_EMAIL=your-email@ebay.com
JIRA_API_TOKEN=your-jira-personal-access-token

# Google Apps Script Web App URL
# Deploy google-apps-script/Code.gs as a Web App — see README.md for instructions
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/a/macros/ebay.com/s/YOUR_DEPLOYMENT_ID/exec

# Microsoft Graph / Outlook
MS_CLIENT_ID=your-azure-app-client-id
MS_TENANT_ID=your-azure-tenant-id
MS_TOKEN_CACHE=~/.config/pm-newsletter/ms_token_cache.json

# Claude API (optional — for AI-powered summarization, falls back to template without it)
ANTHROPIC_API_KEY=sk-ant-your-key-here
