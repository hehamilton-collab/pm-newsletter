# PM Newsletter Configuration
# Copy this file to config.yaml and fill in your details:
#   cp config.yaml.example config.yaml

user:
  name: "Your Name"
  slack_user_id: "U0XXXXXXXXX"   # Slack profile > ... > Copy member ID
  email: "you@company.com"
  timezone: "America/Los_Angeles"

jira:
  project_key: "YOUR_PROJECT"
  initiative: "Your Initiative"
  components:
    - "Component1"
    - "Component2"
  priority_watch:
    - "P1"
    - "P2"

slack:
  decision_keywords:
    - "decision"
    - "agreed"
    - "approved"
    - "shipping"
    - "aligned"
    - "sign off"
    - "go/no-go"
  lookback_days: 7

newsletter:
  output_dir: "~/pm-newsletter/output"
  format: "markdown"  # or "google_doc" if Apps Script is configured
